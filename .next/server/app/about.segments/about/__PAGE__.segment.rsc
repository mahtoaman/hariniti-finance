6:["$","section",null,{"className":"py-20 bg-background","children":["$","div",null,{"className":"container mx-auto px-4 lg:px-8","children":[["$","div",null,{"className":"grid lg:grid-cols-2 gap-16 items-stretch","children":[["$","div",null,{"children":[["$","span",null,{"className":"text-sm font-body font-semibold tracking-widest uppercase text-accent","children":"Our Story"}],["$","h2",null,{"className":"font-display text-3xl md:text-4xl font-bold text-foreground mt-3 mb-6","children":["Bridging the Gap Between ",["$","span",null,{"className":"text-accent","children":"Compliance"}]," and ",["$","span",null,{"className":"text-accent","children":"Growth"}]]}],["$","p",null,{"className":"text-lg text-muted-foreground font-body leading-relaxed mb-6","children":["HariNiti Finance was founded with a clear purpose — to transform the way individuals and businesses approach financial growth. In today’s complex financial environment, people don’t just need advice; they need clarity, structure, and strategic direction. We saw a gap between financial compliance and real financial growth, and HariNiti Finance was built to bridge that gap. We are not just advisors. We are ",["$","strong",null,{"className":"text-foreground","children":"growth partners"}]," committed to building sustainable financial success."]}],["$","p",null,{"className":"text-base text-muted-foreground font-body leading-relaxed","children":"Most firms receive fragmented support — one advisor for finance, another for legal compliance, another for tax, and yet another for technology. HariNiti Finance solves this by bringing Financial Advisory, Funding Solutions, Legal & Statutory Compliance, Taxation, and IT-enabled Business Solutions under one strategic platform. We transform complexity into clarity — ensuring businesses are financially strong, legally compliant, and technologically structured for scalable growth."}]]}],["$","div",null,{"className":"relative rounded-2xl overflow-hidden shadow-card-hover h-full